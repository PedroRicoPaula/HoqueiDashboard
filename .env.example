# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (PostgreSQL):
DATABASE_URL=postgresql://postgres:postgresql123@localhost:5432/hcpdl
# Production (Neon — use the pooler URL for runtime, direct URL for migrations):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Gestão HCPDL

# ── Cloudflare R2 (only needed for production uploads) ────────────────────────
# Leave empty for local dev (files will be saved to public/uploads/)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
