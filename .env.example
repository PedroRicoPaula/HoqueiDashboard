# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (PostgreSQL):
DATABASE_URL=postgresql://postgres:postgresql123@localhost:5432/hoqueimanager
# Production (Neon — use the pooler URL for runtime, direct URL for migrations):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HoqueiManager

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs from Stripe Dashboard
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# ── Cloudflare R2 (uploads: logos, banners) ───────────────────────────────────
# Leave empty for local dev (files will be saved to public/uploads/)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Email transacional (Resend) ───────────────────────────────────────────────
# OBRIGATÓRIO em produção: sem esta chave, os emails de boas-vindas não são enviados
# e os novos clubs não conseguem receber o link para definir a palavra-passe.
# Criar conta em resend.com → API Keys → criar chave → verificar domínio hoqueimanager.com
RESEND_API_KEY=re_...

# ── i18n ──────────────────────────────────────────────────────────────────────
# Supported locales: pt, es, en, fr, it
# Default locale set per-club in DB (Club.language field)
